# dependencies
/.agents
/node_modules
/backend/node_modules
/.npm
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist
/backend/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
backend/npm-debug.log*
