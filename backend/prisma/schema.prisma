generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecurrenceFrequency {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum EventPriority {
  LOW
  NORMAL
  HIGH
}

enum EventStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ReminderChannel {
  PUSH
  EMAIL
  IN_APP
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  timezone     String        @default("UTC")
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  archivedAt   DateTime?

  categories   Category[]
  events       Event[]
  dayNotes     DayNote[]
  habits       Habit[]
  birthdays    Birthday[]
  reminders    Reminder[]
}

model Category {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String
  icon      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  archivedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    Event[]
  habits    Habit[]

  @@index([userId])
}

model Event {
  id          String              @id @default(cuid())
  userId      String
  categoryId  String?
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean             @default(false)
  location    String?
  links       String[]            @default([])
  priority    EventPriority       @default(NORMAL)
  status      EventStatus          @default(SCHEDULED)
  pinned      Boolean             @default(false)
  recurrence  RecurrenceFrequency @default(NONE)
  recurrenceUntil DateTime?
  cancellationReason String?
  cancelledAt DateTime?
  metadata    Json?
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tasks       EventTask[]
  reminders   Reminder[]          @relation("EventReminders")
  rescheduleReminders Reminder[]   @relation("RescheduleReminderForEvent")
  rescheduleTasks EventTask[]      @relation("RescheduleTaskForEvent")

  @@index([userId, startsAt])
  @@index([userId, archivedAt, deletedAt])
}

model EventTask {
  id        String   @id @default(cuid())
  eventId   String
  linkedCancelledEventId String?
  title     String
  done      Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  linkedCancelledEvent Event? @relation("RescheduleTaskForEvent", fields: [linkedCancelledEventId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([linkedCancelledEventId])
}

model DayNote {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  body      String
  pinned    Boolean  @default(false)
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Habit {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String?
  name        String
  color       String
  targetCount Int          @default(1)
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries     HabitEntry[]
}

model HabitEntry {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  count     Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())

  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Reminder {
  id        String          @id @default(cuid())
  userId    String
  eventId   String?
  rescheduleForEventId String?
  title     String?
  channel   ReminderChannel @default(IN_APP)
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event?          @relation("EventReminders", fields: [eventId], references: [id], onDelete: Cascade)
  rescheduleForEvent Event? @relation("RescheduleReminderForEvent", fields: [rescheduleForEventId], references: [id], onDelete: Cascade)

  @@index([userId, remindAt])
  @@index([rescheduleForEventId])
}

model Birthday {
  id        String   @id @default(cuid())
  userId    String
  name      String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
