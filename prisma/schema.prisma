generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  scheduled
  completed
  cancelled
  archived
}

enum Priority {
  low
  normal
  high
  urgent
}

model User {
  id        String     @id
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  events    Event[]
  tasks     Task[]
  categories Category[]
  reminders Reminder[]
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    Event[]

  @@index([userId])
}

model Event {
  id                 String      @id @default(cuid())
  userId             String
  categoryId         String?
  title              String
  description        String?
  startDate          DateTime
  endDate            DateTime?
  allDay             Boolean     @default(false)
  color              String?
  location           String?
  url                String?
  priority           Priority    @default(normal)
  pinned             Boolean     @default(false)
  status             EventStatus @default(scheduled)
  cancellationReason String?
  cancelledAt        DateTime?
  archivedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category           Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tasks              Task[]
  reminders          Reminder[]

  @@index([userId, startDate])
  @@index([userId, status])
  @@index([categoryId])
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  eventId     String?
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  priority    Priority  @default(normal)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reminders   Reminder[]

  @@index([userId])
  @@index([eventId])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  taskId    String?
  title     String
  remindAt  DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, remindAt])
  @@index([eventId])
  @@index([taskId])
}
